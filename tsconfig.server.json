{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "src/server",
    "noEmit": false,
    "declaration": false,
    "sourceMap": true,
    "isolatedModules": false
  },
  "include": ["src/server/**/*.ts"]
}
